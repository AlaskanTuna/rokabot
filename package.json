{
  "name": "rokabot",
  "version": "0.1.0",
  "description": "Server-wide Discord character chatbot embodying Maniwa Roka, powered by Gemini 3.1 Flash Lite via Google ADK",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint src/",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:chat": "tsx scripts/test-chat.ts"
  },
  "dependencies": {
    "@google/adk": "^0.1.0",
    "@google/genai": "^1.0.0",
    "discord.js": "^14.18.0",
    "dotenv": "^16.5.0",
    "pino": "^9.6.0"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^10.0.0",
    "pino-pretty": "^13.0.0",
    "prettier": "^3.6.2",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "vitest": "^3.1.0"
  },
  "engines": {
    "node": ">=24.13.0"
  }
}
